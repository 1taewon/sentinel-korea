# =============================================================================
# Sentinel Korea — backend env template
# =============================================================================
# Copy this file to backend/.env and fill in the keys you need.
# backend/.env is gitignored — never commit your real .env.
#
# Tier:
#   REQUIRED  — backend will not function without it
#   OPTIONAL  — feature degrades or is skipped if missing
# =============================================================================


# === REQUIRED =================================================================

# Google AI Studio key. Used by chatbot, report generator, risk analysis,
# and Gemini-grounded outbreak fetcher. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# KDCA EIDAPI (감염병 통계 API). Get at https://www.data.go.kr — search
# "감염병 발생". Code has a hardcoded fallback so it boots without this, but
# in production you should set your own key.
KDCA_EID_API_KEY=


# === OPTIONAL — domestic signal sources =======================================

# Naver Developers (https://developers.naver.com/apps).
# Used by fetch_naver_news.py + fetch_naver_trends.py for Korean news +
# DataLab keyword trends. Without these, Korea news/trends fall back to
# Google News RSS only.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# NewsAPI (https://newsapi.org). Optional global + Korea news fallback.
# Without it, fetch_korea_news.py and fetch_global_news.py rely on
# Google News RSS only.
NEWS_API_KEY=


# === OPTIONAL — model overrides ===============================================

# Default Gemini model used by chatbot / report / risk-analysis.
# Default: gemini-2.5-flash
GEMINI_MODEL=

# Override just the risk-analysis call (heavier prompt).
# Default: gemini-2.5-flash
RISK_ANALYSIS_MODEL=


# === OPTIONAL — KDCA fetcher =================================================

# If set, fetch_kdca_api fetches that year only. Default: current year.
KDCA_NOTIFIABLE_YEAR=


# === OPTIONAL — Firebase admin auth ==========================================
# If unset, the backend falls back to SENTINEL_ADMIN_TOKEN bearer auth.
# Set EITHER FIREBASE_SERVICE_ACCOUNT_PATH (file path) OR
# FIREBASE_SERVICE_ACCOUNT_JSON (raw JSON inline).

FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Comma-separated allowlist of admin emails. Only these accounts can hit
# admin-protected endpoints (/risk-analysis/analyze, /reports/generate,
# /ingestion/refresh-*, etc).
ADMIN_EMAILS=

# Fallback bearer token when Firebase isn't configured. Used only in dev.
SENTINEL_ADMIN_TOKEN=


# === OPTIONAL — email (FINAL report send) =====================================
# Used by /reports/send. Gmail App Password works for SMTP_PASSWORD.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
REPORT_SENDER_NAME=Sentinel Korea


# === OPTIONAL — runtime / deployment =========================================

# Comma-separated extra CORS origins (e.g. custom domain).
# Default allowed: localhost:5173, localhost:4173, sentinel-korea.vercel.app,
# and any sentinel-korea-*.vercel.app preview URL.
EXTRA_CORS_ORIGINS=

# Where /ingestion/process-folder scans for KDCA files.
# Default (Windows): C:\Users\han75\OneDrive\Desktop\Sentinel_data
# On Linux/macOS, set this to whatever folder you keep KDCA downloads in.
SENTINEL_DATA_DIR=

# Local dev port. Frontend (frontend/.env) should set VITE_API_URL=http://localhost:<this>.
BACKEND_PORT=8001
